doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Panel Admin - Departamento
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")
    style.
      :root {
      --verde1: #99E89D;
      --verde2: #73C883;
      --verde3: #4DA768;
      --verde4: #2E874E;
      --verde5: #006633;
      --blanco: #ffffff;
      --gris: #f4f4f4;
      }
      
      * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
      }
      
      body {
      display: flex;
      background: linear-gradient(135deg, #4CAF50, #81C784);
      }
      
      /* SIDEBAR */
      .sidebar {
      width: 250px;
      min-height: 100vh;
      background: #0d3b2e;
      color: white;
      padding: 20px;
      position: fixed;
      }
      
      .sidebar h2 {
      margin-bottom: 30px;
      }
      
      .sidebar a {
      color: #cce7dc;
      text-decoration: none;
      display: block;
      padding: 10px;
      border-radius: 8px;
      transition: 0.3s;
      }
      
      .sidebar a:hover {
      background: #145c43;
      color: white;
      }
      
      /* MAIN */
      .main {
      margin-left: 260px;
      padding: 30px;
      width: 100%;
      }
      
      /* HEADER */
      .header {
      color: white;
      margin-bottom: 20px;
      }
      
      .header h1 {
      font-size: 2.2rem;
      }
      
      /* TABLA */
      .table-container {
      margin-top: 20px;
      background: white;
      padding: 25px;
      border-radius: 15px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
      }
      
      table {
      width: 100%;
      border-collapse: collapse;
      }
      
      th {
      background: #2e7d32;
      color: white;
      padding: 12px;
      }
      
      td {
      padding: 12px;
      border-bottom: 1px solid #eee;
      }
      
      /* SELECTS */
      select {
      padding: 6px;
      border-radius: 6px;
      border: 1px solid #ccc;
      outline: none;
      }
      
      select:focus {
      border-color: var(--verde3);
      }
      
      /* BOTONES */
      .btn {
      padding: 6px 12px;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
      transition: 0.3s;
      }
      
      .btn-print {
      background: var(--verde4);
      color: white;
      }
      
      .btn-print:hover {
      background: var(--verde5);
      transform: translateY(-1px);
      }
      
      /* FILAS HOVER */
      tr:hover {
      background: #f9f9f9;
      }
      
      .acciones-ticket {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
      align-items: center;
      }
      
      @media print {
      body {
      background: white !important;
      }
      .sidebar {
      display: none !important;
      }
      .main {
      margin-left: 0 !important;
      padding: 16px !important;
      width: 100% !important;
      }
      .header {
      color: #000 !important;
      }
      .table-container {
      box-shadow: none !important;
      }
      tr.fila-oculta-print {
      display: none !important;
      }
      .acciones-ticket .btn {
      display: none !important;
      }
      }
  body
    // SIDEBAR
    .sidebar
      h2 ADMIN DEPTO LIMPIEZA

      a(href="/login")
        i.bi.bi-box-arrow-right
        | Cerrar sesión
    // CONTENIDO
    .main
      .header
        h1 Departamento: Limpieza
        p Gestión de tickets
      // TABLA
      .table-container
        h2 Solicitudes recibidas
        table
          tr
            th ID
            th Ubicación
            th Descripción
            th Estado
            th Prioridad
            th Acciones
          
          each ticket in tickets || []
            tr.ticket-fila(data-ticket-id=ticket.id)
              td= ticket.id
              td= ticket.ubicacion
              td= ticket.descripcion
              td
                select(id=`estado-${ticket.id}`)
                  option(value="Pendiente", selected=ticket.estado === 'Pendiente') Pendiente
                  option(value="En proceso", selected=ticket.estado === 'En proceso') En proceso
                  option(value="Terminado", selected=ticket.estado === 'Terminado') Terminado
              td
                select(id=`prioridad-${ticket.id}`)
                  option(value="Baja", selected=ticket.prioridad === 'Baja') Baja
                  option(value="Media", selected=ticket.prioridad === 'Media') Media
                  option(value="Alta", selected=ticket.prioridad === 'Alta') Alta
              td
                .acciones-ticket
                  button.btn.btn-print(type="button", onclick=`guardarCambios(${ticket.id})`)
                    i.bi.bi-save
                    | Guardar
                  button.btn.btn-print(type="button", onclick=`imprimirTicket(${ticket.id})`)
                    i.bi.bi-printer
                    | Imprimir
          else
            tr
              td(colspan="6", style="text-align: center; padding: 20px;") No hay tickets asignados a este departamento aún.

      //- SCRIPT DE JAVASCRIPT AL FINAL DE TU PUG
      script.
        function imprimirTicket(id) {
          document.querySelectorAll('tr.ticket-fila').forEach(function (tr) {
            if (String(tr.getAttribute('data-ticket-id')) !== String(id)) {
              tr.classList.add('fila-oculta-print');
            }
          });
          window.print();
          document.querySelectorAll('tr.fila-oculta-print').forEach(function (tr) {
            tr.classList.remove('fila-oculta-print');
          });
        }
        function guardarCambios(id) {
          const estado = document.getElementById(`estado-${id}`).value;
          const prioridad = document.getElementById(`prioridad-${id}`).value;
          fetch('/actualizarTicket', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, estado, prioridad })
          })
          .then(async (response) => {
            const data = await response.json().catch(() => ({}));
            if (response.ok && data.ok !== false) {
              alert('Ticket actualizado correctamente.');
            } else {
              alert(data.error || 'No se pudo guardar el cambio.');
            }
          })
          .catch(() => alert('Error de red al contactar el servidor.'));
        }