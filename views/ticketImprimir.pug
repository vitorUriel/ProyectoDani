doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="icon", href="/img/logo.png", type="image/png")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")
    link(rel="stylesheet", href="/css/ticketImprimir.css")
    title Ticket

  body

    button.back-btn(onclick="window.location.href='/adminDepto'") ← Regresar

    .ticket
      h2 SYSTEM TICKETS
      
      //- Agregamos el número de folio formateado
      p Folio: 
        strong= 'TKT-' + ticket.id.toString().padStart(3, '0')

      p Fecha de impresión: 
        span#fecha
      p Hora: 
        span#hora

      .line

      p
        strong Ubicación:
      //- Imprimimos la ubicación real desde la BD
      p= ticket.ubicacion

      p
        strong Descripción del problema:
      //- Imprimimos la descripción real desde la BD
      p= ticket.descripcion

      .line

      // FIRMA
      .firma
        .firma-linea
        p.firma-texto Firma de conformidad

        p.firma-texto 
          | Conste que el trabajo fue realizado correctamente

      .line

      .center
        p ¡Gracias por su solicitud!
    button.btn(onclick="window.print()") Imprimir Ticket

    script.
      const fecha = new Date();

      document.getElementById("fecha").innerText =
        fecha.toLocaleDateString();

      document.getElementById("hora").innerText =
        fecha.toLocaleTimeString();

      // Detectamos si la página se cargó desde la memoria del botón "Atrás"
      window.addEventListener('pageshow', function (event) {
        // event.persisted es true si la página viene del BFCache
        if (event.persisted) {
          // Obligamos al navegador a recargar y preguntarle al servidor
          window.location.reload();
        }
      });