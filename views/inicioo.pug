doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title System Tickets
      link(rel="icon", type="image/png", href="/img/logo.png")

    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")
    style.
      body {
      background: linear-gradient(135deg, #4CAF50, #81C784);
      min-height: 100vh;
      }
      
      .sidebar {
      width: 250px;
      min-height: 100vh;
      background: #0d3b2e;
      color: white;
      position: fixed;
      }
      
      .sidebar h4 {
      font-weight: bold;
      }
      
      .sidebar .logo {
      width: 60px;
      }
      
      .sidebar a {
      color: #cce7dc;
      text-decoration: none;
      display: block;
      padding: 10px;
      border-radius: 8px;
      }
      
      .sidebar a:hover {
      background: #145c43;
      color: white;
      }
      
      .main-content {
      margin-left: 260px;
      padding: 30px;
      }
      
      .card-custom {
      border-radius: 15px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      }
      
      .title-main {
      font-size: 3rem;
      font-weight: bold;
      }
      
      .subtitle {
      color: #2e7d32;
      font-weight: 600;
      }

  body
  
    .sidebar.d-flex.flex-column.p-4
      h4.mb-3 SYSTEM TICKETS
      p.small Gestión eficiente, soluciones rápidas
      img.logo.mb-4(src="https://cdn-icons-png.flaticon.com/512/906/906343.png")
      nav
        a(href="/inicioo")
          i.bi.bi-house-door-fill.me-2
          | Inicio
       
        a(href="/login")
          i.bi.bi-gear.me-2
          | Aplicación

    .main-content
      .d-flex.justify-content-between.align-items-center.mb-4
        div
          h1.title-main.text-white BIENVENIDO
          h3.subtitle SYSTEM TICKETS
        img(src="https://cdn-icons-png.flaticon.com/512/906/906343.png", width="100")
   
      .card.card-custom.p-4.bg-light
        h4.mb-3 ¿Qué es System Tickets?
        p
          | System Tickets es una aplicación diseñada para la gestión eficiente de incidencias y solicitudes dentro de una organización.
          | Permite registrar, dar seguimiento y resolver problemas de manera ordenada, facilitando la comunicación entre usuarios y soporte técnico.
        hr
        h5.mb-3 Funciones principales
        .row.text-center.mt-3
          .col-md-4
            .p-3
              i.bi.bi-pencil-square.fs-1.text-success
              h6.mt-2 Registro de tickets
              p.small Crear incidencias fácilmente
          .col-md-4
            .p-3
              i.bi.bi-search.fs-1.text-success
              h6.mt-2 Seguimiento
              p.small Control 
          .col-md-4
            .p-3
              i.bi.bi-people.fs-1.text-success
              h6.mt-2 Gestión de usuarios
              p.small Administración eficiente
    
      .row.mt-4
        .col-md-4
          .card.card-custom.p-3.text-center
            h6 Creación details 
            h2.text-success Tickets
        .col-md-4
          .card.card-custom.p-3.text-center
            h6 Soluciones 
            h2.text-warning Rápidas
        .col-md-4
          .card.card-custom.p-3.text-center
            h6 Reportes
            h2.text-primary Mensuales