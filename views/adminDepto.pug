doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Panel Admin - Departamento
    link(rel="icon", href="/img/logo.png", type="image/png")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")
    link(rel="stylesheet", href="/css/adminDepto.css")
  body
    .sidebar
      .sidebar-header
        h2 ADMIN DEPTO #{(nombreDepto || 'Departamento').toUpperCase()}
        a.btn-logout(href="/logout")
          i.bi.bi-box-arrow-left 
          | Cerrar sesión
    .main
      .header
        h1 Departamento: #{nombreDepto}
        p Bienvenido, #{nombreUsuario}
        p Gestión de tickets
      .table-container
        h4.mb-3  Solicitudes recibidas
        table
          tr
            th Folio
            th Ubicación
            th Descripción
            th Estado
            th Prioridad
            th Acciones
          
          each ticket in tickets || []
            tr.ticket-fila(data-ticket-id=ticket.id)
              td= ticket.id
              td= ticket.ubicacion
              td= ticket.descripcion
              td
                select(id=`estado-${ticket.id}`)
                  option(value="Pendiente", selected=ticket.estado === 'Pendiente') Pendiente
                  option(value="En proceso", selected=ticket.estado === 'En proceso') En proceso
                  option(value="Terminado", selected=ticket.estado === 'Terminado') Terminado
              td
                select(id=`prioridad-${ticket.id}`)
                  option(value="Baja", selected=ticket.prioridad === 'Baja') Baja
                  option(value="Media", selected=ticket.prioridad === 'Media') Media
                  option(value="Alta", selected=ticket.prioridad === 'Alta') Alta
              td
                .acciones-ticket
                  button.btn.btn-print(type="button", onclick=`guardarCambios(${ticket.id})`)
                    i.bi.bi-save
                    | Guardar
                  a.button.btn.btn-print(onclick="window.location.href='/ticketImprimir/" + ticket.id + "'")
                  
                    i.bi.bi-printer
                    | Imprimir
          else
            tr
              td(colspan="6", style="text-align: center; padding: 20px;") No hay tickets asignados a este departamento aún.

      script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")
      script.
        function guardarCambios(id) {
          const estado = document.getElementById(`estado-${id}`).value;
          const prioridad = document.getElementById(`prioridad-${id}`).value;
          fetch('/actualizarTicket', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ id, estado, prioridad })
          })
          .then(async (response) => {
            const data = await response.json().catch(() => ({}));
            if (response.ok && data.ok !== false) {
              Swal.fire({
                icon: 'success',
                title: 'Actualizado',
                text: 'Ticket actualizado correctamente.',
                showConfirmButton: false,
                timer: 1700,
                toast: true,
                position: 'top-end',
                background: '#effaf0',
                color: '#0f5132',
                timerProgressBar: true,
                showClass: {
                  popup: 'swal2-show',
                  icon: 'swal2-icon-show'
                },
                hideClass: {
                  popup: 'swal2-hide',
                  icon: 'swal2-icon-hide'
                }
              });
            } else {
              Swal.fire({
                icon: 'error',
                title: 'Error',
                text: data.error || 'No se pudo guardar el cambio.',
                confirmButtonColor: '#d33'
              });
            }
          })
          .catch(() => Swal.fire({
            icon: 'error',
            title: 'Error de red',
            text: 'No se pudo contactar al servidor.',
            confirmButtonColor: '#d33'
          }));
        }

    script.
      window.addEventListener('pageshow', function (event) {
        if (event.persisted) {
          window.location.reload();
        }
      });