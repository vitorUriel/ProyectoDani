doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Crear Usuario

    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")

    style.
      :root {
        --verde1: #99E89D;
        --verde2: #73C883;
        --verde3: #4DA768;
        --verde4: #2E874E;
        --verde5: #006633;
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
        font-family: Arial, sans-serif;
      }

      body {
        background: linear-gradient(135deg, #4CAF50, #81C784);
        display: flex;
        justify-content: center;
        align-items: center;
        height: 100vh;
      }

      .form-container {
        background: white;
        padding: 30px;
        width: 420px;
        border-radius: 15px;
        box-shadow: 0 10px 30px rgba(0,0,0,0.3);
      }

      h2 {
        text-align: center;
        color: var(--verde5);
        margin-bottom: 20px;
      }

      .field {
        margin-bottom: 15px;
      }

      .field label {
        font-size: 13px;
        color: #555;
      }

      .field input,
      .field select {
        width: 100%;
        padding: 10px;
        margin-top: 5px;
        border-radius: 8px;
        border: 1px solid #ccc;
        transition: 0.3s;
      }

      .field input:focus,
      .field select:focus {
        border-color: var(--verde3);
        outline: none;
        box-shadow: 0 0 5px rgba(77,167,104,0.4);
      }

      .btn {
        width: 100%;
        padding: 12px;
        background: var(--verde4);
        color: white;
        border: none;
        border-radius: 8px;
        cursor: pointer;
        font-weight: bold;
        transition: 0.3s;
        margin-top: 10px;
      }

      .btn:hover {
        background: var(--verde5);
        transform: translateY(-1px);
      }

      .back-btn {
        margin-top: 10px;
        width: 100%;
        padding: 10px;
        background: var(--verde2);
        color: var(--verde5);
        border: 1px solid var(--verde4);
        border-radius: 8px;
        cursor: pointer;
        transition: 0.3s;
      }

      .back-btn:hover {
        background: var(--verde3);
        color: white;
      }

      .input-icon {
        position: relative;
      }

      .input-icon i {
        position: absolute;
        top: 38px;
        left: 10px;
        color: #888;
      }

      .input-icon input {
        padding-left: 35px;
      }

  body
    // 1. Agregamos el ID al form y quitamos el action/method
    form.form-container#formAlta
      h2
        i.bi.bi-person-plus-fill
        |  Crear Usuario

      .field.input-icon
        label Nombre
        i.bi.bi-person
        input(type="text", name="nombre", required)

      .field.input-icon
        label Correo
        i.bi.bi-envelope
        input(type="email", name="correo", required)

      .field.input-icon
        label Contraseña
        i.bi.bi-lock
        input(type="password", name="password", required)

  
      .field
        label Nivel de Acceso
        // Cambiamos el name a rol_id para que sea directo
        select(name="rol_id", required)
          option(value="") Selecciona un nivel...
          option(value="3") Usuario Normal
          option(value="2") Administrador de Departamento
          option(value="1") Administrador General

      .field
        label Departamento
        select(name="departamento_id", required)
          option(value="") N/A
          option(value="2") Mantenimiento
          option(value="3") Jardinería
          option(value="4") Limpieza
          option(value="5") Soporte

      button.btn(type="submit")
        i.bi.bi-check-circle
        |  Crear Usuario

      button.back-btn(type="button", onclick="window.history.back()")
        i.bi.bi-arrow-left
        |  Regresar

        // Va hasta el final del archivo
script.
  document.getElementById('formAlta').addEventListener('submit', async (e) => {
    // 1. ESTO ES LA MAGIA: Detiene el viaje a la otra página
    e.preventDefault(); 

    // 2. Recolectamos los datos que escribió el usuario
    const formData = new FormData(e.target);
    const data = Object.fromEntries(formData.entries());

    try {
      // 3. Enviamos los datos al servidor de forma "invisible"
      const response = await fetch('/usuarios', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(data)
      });

      // 4. Leemos lo que nos contestó el servidor
      const result = await response.json();

      if (result.success) {
        alert(result.message); // Alerta de éxito
        e.target.reset();      // Limpia los campos del formulario para uno nuevo
        // window.location.href = '/adminGeneral'; // Descomenta esto si quieres mandarlo a otra pantalla al terminar
      } else {
        alert(result.message); // Alerta de error (ej: correo duplicado)
      }

    } catch (error) {
      alert('Error de conexión con el servidor.');
    }
  });

  const selectNivel = document.querySelector('select[name="rol_id"]');
      const selectDepto = document.querySelector('select[name="departamento_id"]');

      selectNivel.addEventListener('change', (e) => {
        const rolSeleccionado = e.target.value;
        
        // Si es Admin General (1) o Usuario (3), bloqueamos el departamento
        if (rolSeleccionado === '1' || rolSeleccionado === '3') {
          selectDepto.value = ""; // Lo regresamos a la opción vacía
          selectDepto.disabled = true; // Lo bloqueamos visualmente
        } else {
          // Si es Admin de Área (2), lo volvemos a habilitar
          selectDepto.disabled = false;
        }
        });