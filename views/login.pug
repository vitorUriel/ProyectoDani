doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Login - System Tickets
    link(rel="icon", href="/img/logo.png", type="image/png")
    link(rel="stylesheet", href="/css/login.css")
  body
    button.back-btn(onclick="window.location.href='/inicioo'") ← Regresar

    .login-container
      h2 SYSTEM TICKETS
      p Acceso al sistema
      form(action="/login", method="POST")
        .input-group
          label Correo electrónico
          input(type="email", name="correo", required)
        .input-group
          label Contraseña
          input(type="password", name="password", required)
        button.btn(type="submit") Iniciar sesión
      .footer
        | © Sistema de tickets

    script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")

    script.
        // 1. Revisamos si la URL trae un parámetro de error
        const urlParams = new URLSearchParams(window.location.search);
        const error = urlParams.get('error');

        // 2. Si hay un error, mostramos la alerta de SweetAlert2
        if (error === 'no_existe') {
            Swal.fire({
                icon: 'error',
                title: 'Usuario no encontrado',
                text: 'El correo electrónico ingresado no está registrado.',
                confirmButtonColor: '#2e7d32'
            });
        } else if (error === 'password') {
            Swal.fire({
                icon: 'error',
                title: 'Contraseña incorrecta',
                text: 'La contraseña ingresada no es válida.',
                confirmButtonColor: '#2e7d32'
            });
        }

        // 3. Limpiamos la URL para evitar que la alerta se repita al recargar
        if (error) {
            window.history.replaceState(null, '', window.location.pathname);
        }

        // 4. Manejo del botón atrás y BFCache
        window.addEventListener('pageshow', function (event) {
            var navigation = window.performance && window.performance.getEntriesByType("navigation");
            var esBotonAtras = event.persisted || (navigation && navigation[0] && navigation[0].type === 'back_forward');
            if (esBotonAtras) {
                window.location.reload();
            }
        });
