doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Login - System Tickets
    link(rel="icon", href="/img/logo.png", type="image/png")
    style.
      :root {
      --verde1: #99E89D;
      --verde2: #73C883;
      --verde3: #4DA768;
      --verde4: #2E874E;
      --verde5: #006633;
      --blanco: #ffffff;
      --gris: #f2f2f2;
      }
      
      * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
      }
      
      body {
      height: 100vh;
      background: linear-gradient(to right, var(--verde3), var(--verde5));
      display: flex;
      justify-content: center;
      align-items: center;
      position: relative;
      }

     
      .back-btn {
      position: absolute;
      top: 20px;
      left: 20px;
      background: var(--verde5);
      color: white;
      border: none;
      padding: 8px 14px;
      border-radius: 6px;
      cursor: pointer;
      font-size: 13px;
      font-weight: bold;
      transition: 0.3s;
      }

      .back-btn:hover {
      background: var(--verde4);
      transform: translateY(-1px);
      }

      .login-container {
      background: var(--blanco);
      padding: 40px;
      width: 350px;
      border-radius: 12px;
      box-shadow: 0 10px 25px rgba(0,0,0,0.2);
      text-align: center;
      }
      
      .login-container h2 {
      margin-bottom: 10px;
      color: var(--verde5);
      }
      
      .login-container p {
      margin-bottom: 25px;
      color: #666;
      font-size: 14px;
      }
      
      .input-group {
      margin-bottom: 20px;
      text-align: left;
      }
      
      .input-group label {
      font-size: 13px;
      color: #333;
      }
      
      .input-group input {
      width: 100%;
      padding: 10px;
      margin-top: 5px;
      border: 1px solid #ccc;
      border-radius: 6px;
      outline: none;
      }
      
      .input-group input:focus {
      border-color: var(--verde3);
      }
      
      .btn {
      width: 100%;
      padding: 12px;
      background: var(--verde4);
      border: none;
      color: white;
      border-radius: 6px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
      }
      
      .btn:hover {
      background: var(--verde5);
      }
      
      .footer {
      margin-top: 15px;
      font-size: 12px;
      color: #888;
      }

  body
    button.back-btn(onclick="window.location.href='/inicioo'") ← Regresar

    .login-container
      h2 SYSTEM TICKETS
      p Acceso al sistema
      form(action="/login", method="POST")
        .input-group
          label Correo electrónico
          input(type="email", name="correo", required)
        .input-group
          label Contraseña
          input(type="password", name="password", required)
        button.btn(type="submit") Iniciar sesión
      .footer
        | © Sistema de tickets

        //- Asegúrate de tener importado SweetAlert2
script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")

script.
    // 1. Revisamos si la URL trae un chisme (ej. misitio.com/login?error=password)
    const urlParams = new URLSearchParams(window.location.search);
    const error = urlParams.get('error');

    // 2. Si hay un error, disparamos la animación bonita
    if (error === 'no_existe') {
        Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: 'El correo ingresado no existe.',
            heightAuto: false,      
            scrollbarPadding: false
        });
    } else if (error === 'password') {
        Swal.fire({
            icon: 'error',
            title: 'Acceso Denegado',
            text: 'La contraseña es incorrecta.',
            heightAuto: false,       
            scrollbarPadding: false
        });
    }

    // 3. Limpiamos la URL para que no se quede pegado el mensaje si recarga la página
    if (error) {
        window.history.replaceState(null, '', window.location.pathname);
    }