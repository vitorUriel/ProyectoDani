doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Login - System Tickets
    link(rel="icon", href="/img/logo.png", type="image/png")
    link(rel="stylesheet", href="/css/login.css")
  body
    button.back-btn(onclick="window.location.href='/inicioo'") ← Regresar

    .login-container
      h2 SYSTEM TICKETS
      p Acceso al sistema
      form(action="/login", method="POST")
        .input-group
          label Correo electrónico
          input(type="email", name="correo", required)
        .input-group
          label Contraseña
          input(type="password", name="password", required)
        button.btn(type="submit") Iniciar sesión
      .footer
        | © Sistema de tickets

        //- Asegúrate de tener importado SweetAlert2
script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")

script.
    // 1. Revisamos si la URL trae un chisme (ej. misitio.com/login?error=password)
    const urlParams = new URLSearchParams(window.location.search);
    const error = urlParams.get('error');

    // 2. Si hay un error, disparamos la animación bonita
    if (error === 'no_existe') {
        Swal.fire({
            icon: 'error',
            title: 'Oops...',
            text: 'El correo ingresado no existe.',
            heightAuto: false,      
            scrollbarPadding: false
        });
    } else if (error === 'password') {
        Swal.fire({
            icon: 'error',
            title: 'Acceso Denegado',
            text: 'La contraseña es incorrecta.',
            heightAuto: false,       
            scrollbarPadding: false
        });
    }

    // 3. Limpiamos la URL para que no se quede pegado el mensaje si recarga la página
    if (error) {
        window.history.replaceState(null, '', window.location.pathname);
    }
  
script.
    window.addEventListener('pageshow', function (event) {
        var navigation = window.performance && window.performance.getEntriesByType("navigation");
        var esBotonAtras = event.persisted || (navigation && navigation[0] && navigation[0].type === 'back_forward');
        if (esBotonAtras) {
            window.location.reload();
        }
    });

  script.
    window.addEventListener('pageshow', function (event) {
        // Chequeo doble: BFCache nativo o API de navegación (botón atrás = tipo 2)
        var esBotonAtras = event.persisted || 
                          (window.performance && window.performance.getEntriesByType("navigation")[0].type === 'back_forward');
        
        if (esBotonAtras) {
            // Recarga obligatoria ignorando la caché local
            window.location.reload(true); 
        }
    });