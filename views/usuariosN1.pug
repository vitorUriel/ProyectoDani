doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Panel Usuario - System Tickets

    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css",
      rel="stylesheet"
    )
    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css",
      rel="stylesheet"
    )

    style.
      body {
        background: linear-gradient(135deg, #4CAF50, #81C784);
        min-height: 100vh;
      }

      .sidebar {
        width: 250px;
        min-height: 100vh;
        background: #0d3b2e;
        color: white;
        position: fixed;
        padding: 20px;
      }

      .sidebar h4 {
        font-weight: bold;
      }

      .sidebar a {
        color: #cce7dc;
        text-decoration: none;
        display: block;
        padding: 10px;
        border-radius: 8px;
        transition: 0.3s;
      }

      .sidebar a:hover {
        background: #145c43;
        color: white;
      }

      .main-content {
        margin-left: 260px;
        padding: 30px;
      }

      .header {
        color: white;
        margin-bottom: 20px;
      }

      .title-main {
        font-size: 2.5rem;
        font-weight: bold;
      }

      .subtitle {
        color: #e8f5e9;
      }

      .departamentos {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 20px;
      }

      .dep-card {
        background: white;
        padding: 20px;
        text-align: center;
        border-radius: 15px;
        cursor: pointer;
        transition: 0.3s;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      }

      .dep-card:hover {
        transform: translateY(-5px);
        background: #e8f5e9;
      }

      .table-container {
        margin-top: 30px;
        background: white;
        padding: 20px;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      }

      table {
        width: 100%;
        border-collapse: collapse;
      }

      th {
        background: #2e7d32;
        color: white;
        padding: 10px;
      }

      td {
        padding: 10px;
        border-bottom: 1px solid #ddd;
      }

      .estado {
        padding: 5px 10px;
        border-radius: 5px;
        color: white;
        font-size: 12px;
      }

      .pendiente {
        background: orange;
      }

      .proceso {
        background: #3498db;
      }

      .terminado {
        background: green;
      }

  body
    .sidebar
      h4.mb-3 SYSTEM TICKETS
      p.small Gestión eficiente
      nav
        a(href="/logout")
          i.bi.bi-box-arrow-right.me-2
          | Cerrar sesión

    .main-content
      .header
        h1.title-main Panel de Usuario
        p.subtitle Gestión de solicitudes

      .departamentos
      
        //- Suponiendo que Mantenimiento es el ID 1 en tu base de datos
        .dep-card(onclick="window.location.href='/ticketUsuario?depto=2'")
          i.bi.bi-tools.fs-2.text-success
          h6.mt-2 Mantenimiento

        //- Suponiendo que Jardinería es el ID 2
        .dep-card(onclick="window.location.href='/ticketUsuario?depto=3'")
          i.bi.bi-tree.fs-2.text-success
          h6.mt-2 Jardinería

        //- Suponiendo que Limpieza es el ID 3
        .dep-card(onclick="window.location.href='/ticketUsuario?depto=4'")
          i.bi.bi-bucket.fs-2.text-success
          h6.mt-2 Limpieza

        //- Suponiendo que Soporte/Sistemas es el ID 4
        .dep-card(onclick="window.location.href='/ticketUsuario?depto=5'")
          i.bi.bi-laptop.fs-2.text-success
          h6.mt-2 Soporte

      .table-container
        h4.mb-3 Mis solicitudes
        table
          tr
            th ID
            th Folio 
            th Descripción
            th Ubicación
            th Estado
            
          //- Verificamos que 'tickets' exista y tenga al menos un elemento
          if tickets && tickets.length > 0
            each ticket, index in tickets
              tr
                td= index + 1
                td= 'TKT-' + ticket.id.toString().padStart(3, '0')
                td= ticket.descripcion
                td= ticket.ubicacion
                td
                  if ticket.estado === 'Pendiente'
                    span.estado.pendiente Pendiente
                  else if ticket.estado === 'En proceso'
                    span.estado.proceso En proceso
                  else
                    span.estado.terminado Terminado
          else
            tr
              td(colspan="5" style="text-align: center; padding: 20px;") No tienes solicitudes registradas.

  //- 1. Importamos la librería SweetAlert2 desde un CDN (agrégalo al final del body)
  script(src="https://cdn.jsdelivr.net/npm/sweetalert2@11")

  script.
    // 2. Al cargar la página, revisamos si la URL tiene el parámetro 'enviado'
    const urlParams = new URLSearchParams(window.location.search);
    
    if (urlParams.get('enviado') === 'true') {
      // 3. Disparamos la alerta bonita
      Swal.fire({
        title: '¡Ticket Enviado!',
        text: 'Tu solicitud ha sido registrada correctamente y pronto será atendida.',
        icon: 'success',
        confirmButtonColor: '#2e7d32',
        confirmButtonText: 'Entendido'
      });

      // 4. Limpiamos la URL para que no vuelva a salir la alerta si el usuario refresca la página
      window.history.replaceState({}, document.title, window.location.pathname);
    }            