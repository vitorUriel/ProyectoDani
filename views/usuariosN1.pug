doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Panel Usuario - System Tickets

    // Bootstrap
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")

    style.
      body {
      background: linear-gradient(135deg, #4CAF50, #81C784);
      min-height: 100vh;
      }

      /* SIDEBAR */
      .sidebar {
      width: 250px;
      min-height: 100vh;
      background: #0d3b2e;
      color: white;
      position: fixed;
      padding: 20px;
      }

      .sidebar h4 {
      font-weight: bold;
      }

      .sidebar a {
      color: #cce7dc;
      text-decoration: none;
      display: block;
      padding: 10px;
      border-radius: 8px;
      transition: 0.3s;
      }

      .sidebar a:hover {
      background: #145c43;
      color: white;
      }

      /* CONTENIDO */
      .main-content {
      margin-left: 260px;
      padding: 30px;
      }

      /* HEADER */
      .header {
      color: white;
      margin-bottom: 20px;
      }

      .title-main {
      font-size: 2.5rem;
      font-weight: bold;
      }

      .subtitle {
      color: #e8f5e9;
      }

      /* TARJETAS DEPARTAMENTOS */
      .departamentos {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 20px;
      }

      .dep-card {
      background: white;
      padding: 20px;
      text-align: center;
      border-radius: 15px;
      cursor: pointer;
      transition: 0.3s;
      box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      }

      .dep-card:hover {
      transform: translateY(-5px);
      background: #e8f5e9;
      }

      /* TABLA */
      .table-container {
      margin-top: 30px;
      background: white;
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.15);
      }

      table {
      width: 100%;
      border-collapse: collapse;
      }

      th {
      background: #2e7d32;
      color: white;
      padding: 10px;
      }

      td {
      padding: 10px;
      border-bottom: 1px solid #ddd;
      }

      /* ESTADOS */
      .estado {
      padding: 5px 10px;
      border-radius: 5px;
      color: white;
      font-size: 12px;
      }

      .pendiente {
      background: orange;
      }

      .proceso {
      background: #3498db;
      }

      .terminado {
      background: green;
      }

  body

    // SIDEBAR MODERNO
    .sidebar
      h4.mb-3 SYSTEM TICKETS
      p.small Gestión eficiente
      nav
        a(href="#")
          i.bi.bi-house-door-fill.me-2
          | Inicio
        a(href="#")
          i.bi.bi-plus-circle.me-2
          | Crear Ticket
        a(href="#")
          i.bi.bi-list-check.me-2
          | Mis Solicitudes
        a(href="/login")
          i.bi.bi-box-arrow-right.me-2
          | Cerrar sesión

    // CONTENIDO
    .main-content
      .header
        h1.title-main Panel de Usuario
        p.subtitle Gestión de solicitudes

      // DEPARTAMENTOS
      .departamentos
        .dep-card
          i.bi.bi-tools.fs-2.text-success
          h6.mt-2 Mantenimiento
        .dep-card
          i.bi.bi-tree.fs-2.text-success
          h6.mt-2 Jardinería
        .dep-card
          i.bi.bi-bucket.fs-2.text-success
          h6.mt-2 Limpieza
        .dep-card
          i.bi.bi-laptop.fs-2.text-success
          h6.mt-2 Soporte

      // TABLA
      .table-container
        h4.mb-3 Mis solicitudes
        table
          tr
            th ID
            th Departamento
            th Descripción
            th Estado
          tr
            td 1
            td Mantenimiento
            td Fuga de agua
            td
              span.estado.pendiente Pendiente
          tr
            td 2
            td Soporte
            td Computadora no enciende
            td
              span.estado.proceso En proceso
          tr
            td 3
            td Limpieza
            td Aula sucia
            td
              span.estado.terminado Terminado