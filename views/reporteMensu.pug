doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Reporte Mensual
    script(src="https://cdn.jsdelivr.net/npm/chart.js")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")
    style.
      :root {
      --verde1: #99E89D;
      --verde2: #73C883;
      --verde3: #4DA768;
      --verde4: #2E874E;
      --verde5: #006633;
      --gris: #f4f4f4;
      }
      
      * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
      }
      
      body {
      display: flex;
      background: linear-gradient(135deg, #4CAF50, #81C784);
      }
      
      .sidebar {
      width: 250px;
      min-height: 100vh;
      background: #0d3b2e;
      color: white;
      padding: 20px;
      position: fixed;
      }
      
      .sidebar h2 {
      margin-bottom: 30px;
      }
      
      .sidebar a {
      color: #cce7dc;
      text-decoration: none;
      display: block;
      padding: 10px;
      border-radius: 8px;
      transition: 0.3s;
      }
      
      .sidebar a:hover {
      background: #145c43;
      color: white;
      }
      
      .main {
      margin-left: 260px;
      padding: 30px;
      width: 100%;
      }
      
      .header {
      color: white;
      margin-bottom: 20px;
      }
      
      .header h1 {
      font-size: 2.2rem;
      }
      
      .card {
      background: white;
      padding: 20px;
      border-radius: 15px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
      margin-top: 20px;
      }
      
      .filtro {
      display: flex;
      align-items: center;
      gap: 10px;
      }
      
      input[type="month"] {
      padding: 8px;
      border-radius: 6px;
      border: 1px solid #ccc;
      }
      
      input[type="month"]:focus {
      border-color: var(--verde3);
      outline: none;
      }
      
      table {
      width: 100%;
      border-collapse: collapse;
      margin-top: 10px;
      }
      
      th {
      background: #2e7d32;
      color: white;
      padding: 12px;
      }
      
      td {
      padding: 12px;
      border-bottom: 1px solid #eee;
      }
      
      tr:hover {
      background: #f9f9f9;
      }
      
      h2 {
      margin-bottom: 10px;
      color: var(--verde5);
      }
  body
    .sidebar
      h2 ADMIN DEPTO
      a(href="/adminGeneral")
        i.bi.bi-ticket-perforated
        | Admin. Gral
      a(href="/login")
        i.bi.bi-box-arrow-right
        | Cerrar sesión
    .main
      .header
        h1 Reporte Mensual
        p Solicitudes por departamento
      .card
        .filtro
          i.bi.bi-calendar
          label Seleccionar mes:
          input(type="month")
      .card
        h2 Resumen
        table
          tr
            th Departamento
            th Total solicitudes
          tr
            td Mantenimiento
            td 20
          tr
            td Jardinería
            td 10
          tr
            td Limpieza
            td 15
          tr
            td Soporte
            td 25
      