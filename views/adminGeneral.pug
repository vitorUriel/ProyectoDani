doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Admin General
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")
    script.
      window.addEventListener('pageshow', function (event) {
        if (event.persisted) {
          window.location.reload();
        }
      });
    link(rel="stylesheet", href="/css/adminGeneral.css")
  body
    .app
      .sidebar
        h2 ADMIN GENERAL
        nav
          a(href="/reporteMensual")
            i.bi.bi-bar-chart-fill
            | Reportes Mensuales
          a(href="/logout")
            i.bi.bi-box-arrow-right
            | Cerrar sesión

      .main
        .header
          h1 Gestión de Usuarios
          p Control centralizado de acceso

        .card
          .card-grid
            h2 Usuarios registrados
            button.btn.btn-primary(onclick="window.location.href='/altasUsuario'")
              i.bi.bi-person-plus
              span.ms-2 Nuevo usuario

          form(method="get", action="/adminGeneral")
            .filter-panel
              input(type="text", name="q", placeholder="Buscar por nombre o correo", value=(query && query.q) || '')
              select(name="rol")
                option(value="") Todos los roles
                option(value="1" selected=(query && query.rol == '1')) Admin General
                option(value="2" selected=(query && query.rol == '2')) Admin Área
                option(value="3" selected=(query && query.rol == '3')) Usuario
              select(name="departamento")
                option(value="") Todos los departamentos
                each dep in departamentos
                  option(value=dep.id selected=(query && query.departamento == dep.id))= dep.nombre
              button.btn(type="submit") Filtrar

          table
            thead
              tr
                th ID
                th Nombre
                th Correo
                th Rol
                th Departamento
                th Acciones
            tbody
              each usuario in usuarios
                tr
                  td= usuario.id
                  td= usuario.nombre
                  td= usuario.correo
                  td= usuario.rol_nombre || usuario.rol_id
                  td= usuario.departamento_nombre || usuario.departamento_id || '-'
                  td
                    .action-group
                      form(method="post", action=`/usuarios/${usuario.id}/eliminar`, style="display:inline")
                        button.action-delete(type="submit", onclick="return confirm('¿Eliminar usuario?')") Eliminar
              if usuarios.length === 0
                tr.empty-row
                  td(colspan="6") No hay usuarios registrados aún.
script.
    window.addEventListener('pageshow', function (event) {
        // Chequeo doble: BFCache nativo o API de navegación (botón atrás = tipo 2)
        var esBotonAtras = event.persisted || 
                          (window.performance && window.performance.getEntriesByType("navigation")[0].type === 'back_forward');
        
        if (esBotonAtras) {
            // Recarga obligatoria ignorando la caché local
            window.location.reload(true); 
        }
    });