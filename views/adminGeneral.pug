doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Admin General
    link(href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css", rel="stylesheet")
    style.
      :root {
      --verde1: #99E89D;
      --verde2: #73C883;
      --verde3: #4DA768;
      --verde4: #2E874E;
      --verde5: #006633;
      }
      
      * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
      }
      
      body {
      display: flex;
      background: linear-gradient(135deg, #4CAF50, #81C784);
      }
      
   
      .sidebar {
      width: 250px;
      min-height: 100vh;
      background: #0d3b2e;
      color: white;
      padding: 20px;
      position: fixed;
      }
      
      .sidebar h2 {
      margin-bottom: 30px;
      }
      
      .sidebar a {
      color: #cce7dc;
      text-decoration: none;
      display: block;
      padding: 10px;
      border-radius: 8px;
      transition: 0.3s;
      }
      
      .sidebar a:hover {
      background: #145c43;
      color: white;
      }
      
      
      .main {
      margin-left: 260px;
      padding: 30px;
      width: 100%;
      }
      
     
      .header {
      color: white;
      margin-bottom: 20px;
      }
      
      .header h1 {
      font-size: 2.2rem;
      }
      
     
      .card {
      background: white;
      padding: 25px;
      border-radius: 15px;
      box-shadow: 0 8px 20px rgba(0,0,0,0.2);
      }
      
      
      .btn {
      padding: 10px 15px;
      background: var(--verde4);
      color: white;
      border: none;
      border-radius: 8px;
      cursor: pointer;
      font-weight: bold;
      transition: 0.3s;
      margin-bottom: 15px;
      }
      
      .btn:hover {
      background: var(--verde5);
      transform: translateY(-1px);
      }
      
      
      table {
      width: 100%;
      border-collapse: collapse;
      }
      
      th {
      background: #2e7d32;
      color: white;
      padding: 12px;
      }
      
      td {
      padding: 12px;
      border-bottom: 1px solid #eee;
      }
      
      tr:hover {
      background: #f9f9f9;
      }
      
      
      h2 {
      margin-bottom: 10px;
      color: var(--verde5);
      }
  body
    .sidebar
      h2 ADMIN GENERAL
      a(href="/reporteMensual")
        i.bi.bi-house-door-fill
        | Reportes Mensuales
      a(href="/logout")
        i.bi.bi-box-arrow-right
        | Cerrar sesión

    .main
      .header
        h1 Gestión de Usuarios
        p Administración del sistema

      .card
        button.btn(onclick="window.location.href='/altasUsuario'")
          i.bi.bi-person-plus
          | Nuevo Usuario
        h2 Lista de usuarios
        table
          tr
            th ID
            th Nombre
            th Correo
            th Nivel (Rol ID)
            th Departamento

          each usuario in usuarios
            tr
              td= usuario.id
              td= usuario.nombre
              td= usuario.correo
              td= usuario.rol_id
              td= usuario.departamento_id ? usuario.departamento_id : '-'

          if usuarios.length === 0
            tr
              td(colspan="5" style="text-align: center;") No hay usuarios registrados aún.