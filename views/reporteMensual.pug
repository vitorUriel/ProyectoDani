doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    link(rel="stylesheet", href="/css/reporteMensual.css")
    title Reporte Mensual

    script(src="https://cdn.jsdelivr.net/npm/chart.js")
    link(
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css",
      rel="stylesheet"
    )

    

  body
    .sidebar
      h2 ADMIN DEPTO
      nav
        a(href="/adminGeneral")
          i.bi.bi-ticket-perforated.me-2
          | Admin. Gral

        a(href="/logout")
          i.bi.bi-box-arrow-right.me-2
          | Cerrar sesión

    .main
      .header
        h1 Reporte Mensual
        p Solicitudes por departamento

      .card
        .filtro
          i.bi.bi-calendar
          label Seleccionar mes:

          input(
            type="month",
            value=mesSeleccionado,
            onchange="window.location.href='/reporteMensual?mes=' + this.value"
          )

      .card
        h2 Resumen

        table
          tr
            th Departamento
            th Total solicitudes

          if estadisticas && estadisticas.length > 0
            each fila in estadisticas
              tr
                td= fila.departamento
                td= fila.total
          else
            tr
              td(
                colspan="2",
                style="text-align: center; padding: 20px;"
              )
                | No hay datos registrados para este mes.

    script.
      // Detectamos si la página se cargó desde la memoria del botón "Atrás"
      window.addEventListener('pageshow', function (event) {
        // event.persisted es true si la página viene del BFCache
        if (event.persisted) {
          // Obligamos al navegador a recargar y preguntarle al servidor
          window.location.reload();
        }
      });       