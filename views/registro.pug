doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    title Alta de usuarios | System Tickets
    // Bootstrap
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css", rel="stylesheet")
    style.
      body {
      background: linear-gradient(135deg, #2e7d32, #81c784);
      min-height: 100vh;
      font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
      }
      
      .navbar-custom {
      background: #0d3b2e;
      color: white;
      padding: 15px 30px;
      font-weight: 600;
      }
      
      .navbar-custom a {
      color: white;
      text-decoration: none;
      margin-left: 20px;
      font-weight: 500;
      }
      
      .form-container {
      max-width: 700px;
      margin: 50px auto;
      background: #ffffff;
      padding: 40px;
      border-radius: 15px;
      box-shadow: 0 10px 30px rgba(0,0,0,0.2);
      }
      
      .form-title {
      color: #1b5e20;
      font-weight: 600;
      }
      
      .form-label {
      font-weight: 500;
      color: #2e7d32;
      }
      
      .form-control, .form-select {
      border-radius: 8px;
      }
      
      .btn-custom {
      background-color: #2e7d32;
      border: none;
      padding: 10px 20px;
      border-radius: 8px;
      font-weight: 500;
      }
      
      .btn-custom:hover {
      background-color: #1b5e20;
      }
  body
    // 🔹 Navbar
    .navbar-custom.d-flex.justify-content-between
      div SYSTEM TICKETS
      div
        a(href="#") Regresar
        a(href="#") Ingresar
    // 🔹 Formulario
    .form-container
      h3.text-center.mb-4.form-title Alta de Usuario
      form
        // Nombre y Apellido
        .row
          .col-md-6.mb-3
            label.form-label Nombre
            input.form-control(type="text", placeholder="Ingrese nombre")
          .col-md-6.mb-3
            label.form-label Apellido paterno
            input.form-control(type="text", placeholder="Ingrese apellido")
        // Apellido y Email
        .row
          .col-md-6.mb-3
            label.form-label Apellido materno
            input.form-control(type="text", placeholder="Ingrese apellido")
          .col-md-6.mb-3
            label.form-label Correo electrónico
            input.form-control(type="email", placeholder="ejemplo@correo.com")
        // Password
        .mb-3
          label.form-label Contraseña
          input.form-control(type="password", placeholder="Ingrese contraseña")
        // Área
        .mb-4
          label.form-label Área
          select.form-select
            option(selected, disabled) Seleccione un área
            option Soporte
            option Mantenimiento
            option Jardneria
            option Limpieza
        // Botón
        .text-start
          button.btn.btn-custom Registrar usuario
